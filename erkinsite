  <style>
    body {
      margin: 0;
      font-family: Arial;
      background: #0f172a;
      color: white;
    }

    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15px 25px;
      background: #111827;
      position: sticky;
      top: 0;
    }

    .logo {
      font-size: 20px;
      font-weight: bold;
      color: #22c55e;
    }

    button {
      margin-left: 5px;
      padding: 8px 12px;
      border: none;
      border-radius: 8px;
      background: #22c55e;
      cursor: pointer;
      font-weight: bold;
      transition: 0.2s;
    }

    button:hover {
      transform: scale(1.05);
    }

    .hero {
      text-align: center;
      padding: 90px 20px;
      background: linear-gradient(135deg, #1e293b, #0f172a);
    }

    .hero h1 {
      font-size: 36px;
    }

    .btn {
      display: inline-block;
      padding: 12px 25px;
      background: #22c55e;
      color: black;
      text-decoration: none;
      border-radius: 10px;
      font-weight: bold;
      transition: 0.2s;
    }

    .btn:hover {
      transform: translateY(-3px);
    }

    .section {
      padding: 60px 20px;
      text-align: center;
    }

    .cards {
      display: flex;
      justify-content: center;
      gap: 15px;
      flex-wrap: wrap;
    }

    .card {
      background: #1e293b;
      padding: 20px;
      border-radius: 12px;
      width: 250px;
      transition: 0.3s;
    }

    .card:hover {
      transform: translateY(-5px);
    }

    footer {
      text-align: center;
      padding: 20px;
      background: #000;
    }
    * мини игра */
    .game {
      margin-top: 5px;
     }
  </style>
</head>

